# Copy to .env and fill with secure random values.
# setup.sh will generate .env automatically on first run.

POSTGRES_PASSWORD=
LITELLM_MASTER_KEY=sk-
LITELLM_SALT_KEY=sk-
UI_USERNAME=admin
UI_PASSWORD=

# Cloudflare Tunnel token — only needed for the "tunnel" profile.
# Get it from: Cloudflare dashboard → Zero Trust → Networks → Tunnels → (your tunnel)
TUNNEL_TOKEN=
